---
import Icon from "./Icon.astro";
---

<section aria-labelledby="contact-info-title" class="space-y-6">
  <h3 id="contact-info-title" class="sr-only">Información de contacto</h3>

  <dl class="space-y-6">

    <div class="flex gap-4 items-start">
      <div class="bg-amber-100 p-3 rounded-xl text-amber-600" aria-hidden="true">
        <Icon name="mail" size={24} />
      </div>
      <div>
        <dt class="font-bold">Email</dt>
        <dd class="text-gray-600">soporte@tenerifetaxi.com</dd>
      </div>
    </div>

    <div class="flex gap-4 items-start">
      <div class="bg-amber-100 p-3 rounded-xl text-amber-600" aria-hidden="true">
        <Icon name="clock" size={24} />
      </div>
      <div>
        <dt class="font-bold">Horario</dt>
        <dd class="text-gray-600">Lunes a Domingo, 24 horas</dd>
      </div>
    </div>

  </dl>
</section>