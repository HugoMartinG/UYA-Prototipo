---
import Icon from "./Icon.astro";
---

<section class="relative h-[80vh] flex items-center bg-gray-900 text-white">
  <div class="absolute inset-0 opacity-50">
    <img
      src="https://images.pexels.com/photos/29781598/pexels-photo-29781598.jpeg"
      alt=""
      class="w-full h-full object-cover"
    />
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4">
    <h1 class="text-5xl md:text-7xl font-bold mb-6">
      Tu traslado en Tenerife,<br />
      <span class="text-amber-500 italic">sin complicaciones.</span>
    </h1>


    <a
      href="/booking"
      class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white px-8 py-4 rounded-full font-bold text-lg transition-transform hover:scale-105"
    >
      Reservar Ahora <Icon name="chevron-right" size={20} />
    </a>
  </div>
</section>
