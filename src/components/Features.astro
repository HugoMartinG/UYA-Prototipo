---
import Icon from "./Icon.astro";
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-12">
    
    <div class="space-y-4">
      <div class="text-amber-600">
        <Icon name="clock" size={40} />
      </div>
      <h3 class="text-2xl font-bold">Puntualidad 24/7</h3>
      <p class="text-gray-600">
        Monitoreamos tu vuelo para estar allí justo cuando aterrices.
      </p>
    </div>

    <div class="space-y-4">
      <div class="text-amber-600">
        <Icon name="map-pin" size={40} />
      </div>
      <h3 class="text-2xl font-bold">Toda la Isla</h3>
      <p class="text-gray-600">
        Traslados a cualquier hotel o dirección en Tenerife.
      </p>
    </div>

    <div class="space-y-4">
      <div class="text-amber-600">
        <Icon name="car" size={40} />
      </div>
      <h3 class="text-2xl font-bold">Flota Premium</h3>
      <p class="text-gray-600">
        Vehículos modernos con aire acondicionado y gran capacidad.
      </p>
    </div>

  </div>
</section>
