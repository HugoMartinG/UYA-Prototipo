---
import Icon from "./Icon.astro";
---

<form id="manage-form" class="space-y-6" aria-describedby="manage-help">
  <p id="manage-help" class="sr-only">
    Introduce tu código de reserva y tu correo electrónico.
  </p>

  <div aria-live="polite" id="manage-status" class="sr-only"></div>

  <fieldset class="space-y-4">
    <legend class="font-semibold text-lg">Buscar Reserva</legend>

    <div class="space-y-2">
      <label for="code" class="block font-semibold">Código de Reserva</label>
      <input
        type="text"
        id="code"
        name="code"
        required
        aria-required="true"
        aria-invalid="false"
        aria-describedby="code-help code-error"
        placeholder="Ej: TF12345"
        autocomplete="off"
        class="w-full p-4 bg-gray-50 border rounded-xl focus-ring uppercase"
      />
      <p id="code-help" class="text-sm text-gray-500">
        Introduce el código que recibiste por email.
      </p>
      <p id="code-error" class="text-red-600 text-sm hidden">
        Introduce un código válido.
      </p>
    </div>

    <div class="space-y-2">
      <label for="email" class="block font-semibold">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        aria-required="true"
        aria-invalid="false"
        aria-describedby="email-error"
        autocomplete="email"
        class="w-full p-4 bg-gray-50 border rounded-xl focus-ring"
      />
      <p id="email-error" class="text-red-600 text-sm hidden">
        Introduce un correo electrónico válido.
      </p>
    </div>

  </fieldset>

  <button
    type="submit"
    aria-label="Buscar reserva"
    class="w-full bg-gray-900 text-white font-bold py-4 rounded-xl hover:bg-black transition-colors flex items-center justify-center gap-2 focus-ring"
  >
    <Icon name="search" size={20} /> Buscar Reserva
  </button>
</form>
