---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Tenerife Taxi Transfers</title>

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">

    <!-- Skip link accesible -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus-ring px-4 py-2 bg-white text-black">
      Saltar al contenido principal
    </a>

    <header>
      <Navbar />
    </header>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer/>
  </body>
</html>

<style is:global>
  :root {
    --accent: #f59e0b;
  }

  html {
    font-family: "Inter", sans-serif;
    scroll-behavior: smooth;
  }

  h1,
  h2,
  h3 {
    font-family: "Playfair Display", serif;
  }

  .focus-ring:focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }

  /* Clase sr-only accesible */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>